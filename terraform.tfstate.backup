            "id": "/job/first-pipeline",
            "name": "first-pipeline",
            "template": "\u003c?xml version='1.1' encoding='UTF-8'?\u003e\r\n\u003cflow-definition plugin=\"workflow-job\"\u003e\r\n    \u003cactions/\u003e\r\n    \u003cdescription\u003eCreated by Terraform\u003c/description\u003e\r\n    \u003ckeepDependencies\u003efalse\u003c/keepDependencies\u003e\r\n\r\n    \u003cproperties/\u003e\r\n\r\n    \u003cdefinition class=\"org.jenkinsci.plugins.workflow.cps.CpsFlowDefinition\"\u003e\r\n\r\n        \u003cscript\u003e\r\n\r\npipeline {\r\n\r\n    agent any\r\n\r\n    parameters {\r\n\r\n        choice(\r\n            name: 'ENVIRONMENT',\r\n            choices: ['dev','stg','prod'],\r\n            description: 'Select Environment'\r\n        )\r\n\r\n    }\r\n\r\n    stages {\r\n\r\n        stage('Hello World') {\r\n\r\n            steps {\r\n\r\n                echo \"Hello World from ${params.ENVIRONMENT}\"\r\n\r\n            }\r\n\r\n        }\r\n\r\n        stage('Hello Jenkins') {\r\n\r\n            steps {\r\n\r\n                echo \"Hello Jenkins from ${params.ENVIRONMENT}\"\r\n\r\n                error(\"Testing Email Notification\")\r\n\r\n            }\r\n\r\n        }\r\n\r\n    }\r\n\r\n    post {\r\n\r\n        success {\r\n\r\n            echo \"Pipeline completed successfully!\"\r\n\r\n        }\r\n\r\n        failure {\r\n\r\n    echo \"Pipeline failed!\"\r\n\r\n    emailext(\r\n        to: 'bedo2meme@gmail.com',\r\n        subject: \"❌ Build Failed: ${env.JOB_NAME}\",\r\n        mimeType: 'text/html',\r\n        body: \"\"\"\r\n        \u003ch2\u003eBuild Failed\u003c/h2\u003e\r\n\r\n        \u003cp\u003e\u003cb\u003eJob:\u003c/b\u003e ${env.JOB_NAME}\u003c/p\u003e\r\n\r\n        \u003cp\u003e\u003cb\u003eBuild Number:\u003c/b\u003e ${env.BUILD_NUMBER}\u003c/p\u003e\r\n\r\n        \u003cp\u003e\u003cb\u003eURL:\u003c/b\u003e\r\n        \u003ca href=\"${env.BUILD_URL}\"\u003e\r\n        ${env.BUILD_URL}\r\n        \u003c/a\u003e\r\n        \u003c/p\u003e\r\n        \"\"\"\r\n    )\r\n\r\n}\r\n\r\n    }\r\n\r\n}\r\n\r\n        \u003c/script\u003e\r\n\r\n        \u003csandbox\u003etrue\u003c/sandbox\u003e\r\n\r\n    \u003c/definition\u003e\r\n\r\n    \u003ctriggers/\u003e\r\n\r\n    \u003cdisabled\u003efalse\u003c/disabled\u003e\r\n\r\n\u003c/flow-definition\u003e\r\n\r\n"
